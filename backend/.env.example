# ── VirusTotal API Key ──
VT_API_KEY=your_virustotal_api_key_here

# ── Post-Quantum Cryptography ──
# Set to 'true' when liboqs-python is installed (Linux/WSL required)
# When false: AES-256-GCM + KMS envelope encryption only (still production-grade)
# When true: Adds ML-KEM-768 (Kyber) + ML-DSA-65 (Dilithium) quantum resistance
PQC_ENABLED=true

# ── Docker Configuration (Layer 3 & 4) ──
# ClamAV Docker image (persistent clamd daemon on TCP 3310)
CLAMAV_DOCKER_IMAGE=clamav/clamav@sha256:d8c031c26026a27e366fd2fbd7f96b27eb9d1b10ec870d8597bf681944cc996d
CLAMD_HOST=127.0.0.1
CLAMD_PORT=3310

# Sandbox Docker image (ephemeral containers)
SANDBOX_DOCKER_IMAGE=python:3.11-slim@sha256:32ece7335d03ce4bafda8ad0c7e2af31559e31dcd839defc882ea12933d6eafe
SANDBOX_TIMEOUT=10